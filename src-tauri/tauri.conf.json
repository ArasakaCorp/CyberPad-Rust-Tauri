{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberPad",
  "version": "0.1.2",
  "identifier": "com.Arasaka.CyberPad",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CyberPad",
        "width": 1100,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "fileAssociations": [
      {
        "ext": ["txt", "log", "md"],
        "name": "CyberPad Note",
        "description": "CyberPad text note"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
  }